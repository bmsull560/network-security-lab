{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "evidence_bundle",
  "title": "Evidence Bundle",
  "description": "Structured, sanitized alert data passed to the LLM analyst. Never contains raw log lines.",
  "type": "object",
  "required": ["bundle_id", "generated_at", "alerts", "context"],
  "additionalProperties": false,
  "properties": {
    "bundle_id": {
      "type": "string",
      "description": "Unique identifier for this bundle (UUID)"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp when the bundle was assembled"
    },
    "alerts": {
      "type": "array",
      "description": "Structured alert records. String fields are truncated to maxLength.",
      "items": {
        "type": "object",
        "required": ["alert_id", "rule_id", "rule_description", "level", "timestamp", "log_type"],
        "additionalProperties": false,
        "properties": {
          "alert_id": { "type": "string" },
          "rule_id": { "type": "integer" },
          "rule_description": { "type": "string", "maxLength": 512 },
          "level": { "type": "integer", "minimum": 0, "maximum": 15 },
          "timestamp": { "type": "string", "format": "date-time" },
          "log_type": {
            "type": "string",
            "enum": ["conn", "dns", "ssl", "notice", "software", "unknown"]
          },
          "src_ip": { "type": "string", "maxLength": 45 },
          "dst_ip": { "type": "string", "maxLength": 45 },
          "dst_port": { "type": "integer", "minimum": 0, "maximum": 65535 },
          "protocol": { "type": "string", "maxLength": 16 },
          "dns_query": { "type": "string", "maxLength": 256 },
          "dns_rcode": { "type": "string", "maxLength": 32 },
          "ssl_validation_status": { "type": "string", "maxLength": 128 },
          "ssl_server_name": { "type": "string", "maxLength": 256 },
          "conn_state": { "type": "string", "maxLength": 16 },
          "conn_duration_seconds": { "type": "number" },
          "conn_orig_bytes": { "type": "integer" },
          "conn_resp_bytes": { "type": "integer" }
        }
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "time_window_minutes": { "type": "integer" },
        "total_alerts_in_window": { "type": "integer" },
        "unique_src_ips": {
          "type": "array",
          "items": { "type": "string", "maxLength": 45 },
          "maxItems": 20
        },
        "rule_ids_present": {
          "type": "array",
          "items": { "type": "integer" }
        }
      }
    }
  }
}
