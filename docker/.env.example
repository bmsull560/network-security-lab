# ============================================================
# network-security-lab — Docker environment configuration
# Copy this file to docker/.env and fill in all values.
# NEVER commit docker/.env to version control.
# ============================================================

# Wazuh version — pin to a specific release, never use "latest"
WAZUH_VERSION=4.12.0

# Wazuh indexer (OpenSearch) credentials
INDEXER_USERNAME=admin
INDEXER_PASSWORD=CHANGE_ME_strong_password_here

# Wazuh API credentials (admin — for operator use only)
WAZUH_API_USERNAME=wazuh-wui
WAZUH_API_PASSWORD=CHANGE_ME_strong_password_here

# Wazuh dashboard credentials
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=CHANGE_ME_strong_password_here

# Wazuh manager registration password (used by agents to enroll)
WAZUH_REGISTRATION_PASSWORD=CHANGE_ME_strong_password_here

# Network — set to your local subnet for Wazuh indexer binding
# Example: 192.168.1.0/24
LOCAL_NETWORK=192.168.1.0/24

# Ollama model (Phase 6 — LLM assistant)
# Options: mistral:7b-instruct, llama3:8b, phi3:mini
OLLAMA_MODEL=mistral:7b-instruct

# LLM backend: "ollama" (default, local) or "openrouter" (cloud fallback)
# WARNING: openrouter sends evidence bundles to a cloud API.
# Raw logs are NEVER sent regardless of this setting.
LLM_BACKEND=ollama

# OpenRouter API key (only required if LLM_BACKEND=openrouter)
OPENROUTER_API_KEY=

# Wazuh read-only API credentials (for LLM service — Phase 6)
WAZUH_READONLY_USERNAME=llm-analyst
WAZUH_READONLY_PASSWORD=CHANGE_ME_strong_readonly_password_here

# LLM service audit log path (inside container)
# Default: /app/audit/audit.jsonl (persisted in named Docker volume llm-audit-logs)
# To write to a host path, add a bind mount in docker-compose.override.yml
AUDIT_LOG_PATH=/app/audit/audit.jsonl

# LLM inference timeout in seconds (increase for large models on slow hardware)
LLM_TIMEOUT_SECONDS=120
